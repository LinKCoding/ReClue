{
  "name": "reclue-extension",
  "version": "0.1.0",
  "description": "ReClue browser extension — alternative crossword clues and answers from a historical clue database.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:firefox": "tsc --noEmit && cross-env BROWSER=firefox vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.7.4",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
}
